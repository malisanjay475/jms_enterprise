# Copy this file to BACKEND/.env for local testing against the v1 database shape.
# This prevents the backend from falling back to the old jpsms defaults.

NODE_ENV=development
PORT=3000

# Local v1 PostgreSQL clone.
# To see the same factories as 9092/9093, restore a copy of the v1 data into this database.
DB_HOST=localhost
DB_PORT=5432
DB_USER=jms_v1
DB_PASSWORD=replace_with_your_local_v1_password
DB_NAME=jms_v1

# Main server runtime defaults for local testing.
SERVER_TYPE=MAIN
MAIN_SERVER_URL=http://72.62.228.195:9092
LOCAL_FACTORY_ID=
SYNC_API_KEY=
GEMINI_API_KEY=
APP_GIT_SHA=local-dev

# Local server agent stays off for normal local UI testing.
LOCAL_SERVER_AGENT_ENABLED=0
LOCAL_SERVER_NODE_ID=
LOCAL_SERVER_NODE_KEY=
LOCAL_SERVER_PUBLIC_IP=
LOCAL_SERVER_HEARTBEAT_INTERVAL_MS=60000
