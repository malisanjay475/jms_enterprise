STITCH_API_BASE_URL=https://api.stitch.design/v1
STITCH_API_TOKEN=your_stitch_api_token

# Optional:
# STITCH_AUTH_HEADER=Authorization
# STITCH_TOKEN_PREFIX=Bearer

# Push local QC design to Stitch:
# STITCH_PUSH_PATH=/designs/import
# STITCH_PUSH_METHOD=POST
# STITCH_PAYLOAD_MODE=html_css
# STITCH_COMPONENT_NAME=QCSupervisor Login
# STITCH_TARGET_FILE=PUBLIC/QCSupervisor.html
# STITCH_PROJECT_ID=your_project_id
# STITCH_FILE_ID=your_file_id
