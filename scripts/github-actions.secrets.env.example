# Copy this file to github-actions.secrets.env (same folder) and fill values.
# That file is gitignored. Then run:
#   Windows:  pwsh -File scripts/bootstrap-github-actions.ps1
#   mac/Linux: bash scripts/bootstrap-github-actions.sh
#
# Requires: GitHub CLI (https://cli.github.com/) and `gh auth login` with repo admin.

# --- Required for automatic VPS deploy (SSH) ---
HOSTINGER_SSH_HOST=72.62.228.195
HOSTINGER_SSH_USER=root
VPS_DEPLOY_PATH=/opt/jms-enterprise
VPS_POSTGRES_PASSWORD=use_a_long_random_password_here

# --- SSH: use password OR key (not both required) ---
VPS_SSH_PASSWORD=

# If using key instead of password, point to the private key file (path relative to repo root or absolute):
# HOSTINGER_SSH_KEY_FILE=.deploy-keys/id_rsa
HOSTINGER_SSH_KEY_FILE=

# Only if the key file is encrypted:
HOSTINGER_SSH_KEY_PASSPHRASE=

# --- Optional ---
VPS_GEMINI_API_KEY=
# If GHCR package stays private, create a fine-grained PAT with read:packages for this repo owner:
GHCR_PULL_TOKEN=

# --- Optional production overrides ---
V1_HTTP_PORT=9091
MAIN_SERVER_URL=
LOCAL_FACTORY_ID=
SYNC_API_KEY=
DB_BACKUP_BEFORE_DEPLOY=1

# --- Optional staging deploy ---
STAGING_HOSTINGER_SSH_HOST=
STAGING_HOSTINGER_SSH_USER=
STAGING_VPS_DEPLOY_PATH=
STAGING_VPS_POSTGRES_PASSWORD=
STAGING_VPS_SSH_PASSWORD=
STAGING_HOSTINGER_SSH_KEY_FILE=
STAGING_HOSTINGER_SSH_KEY=
STAGING_HOSTINGER_SSH_KEY_PASSPHRASE=
STAGING_VPS_GEMINI_API_KEY=
STAGING_V1_HTTP_PORT=9092
STAGING_MAIN_SERVER_URL=
STAGING_LOCAL_FACTORY_ID=
STAGING_SYNC_API_KEY=
STAGING_DB_BACKUP_BEFORE_DEPLOY=1
